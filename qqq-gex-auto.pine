// This Pine Script works on TradingView - copy and paste directly
//@version=5
indicator("QQQ GEX Levels", overlay=true)

// ============================================================
// GEX CONFLOENCE LEVELS
// Copy values from your data.json into the inputs below
// ============================================================

// Colors
color GREEN = color.green
color RED = color.red  
color YELLOW = color.yellow

// ===== LEVEL 1 =====
bool show1 = true
float price1 = 930.00
string label1 = "⚡3 Agg CW + Max Pain + Top 10 GEX"
color color1 = GREEN

// ===== LEVEL 2 =====
bool show2 = false
float price2 = 0.00
string label2 = ""
color color2 = GREEN

// ===== LEVEL 3 =====
bool show3 = false
float price3 = 0.00
string label3 = ""
color color3 = RED

// ===== LEVEL 4 =====
bool show4 = false
float price4 = 0.00
string label4 = ""
color color4 = YELLOW

// ===== LEVEL 5 =====
bool show5 = false
float price5 = 0.00
string label5 = ""
color color5 = color.white

// ============================================================
// DO NOT EDIT BELOW
// ============================================================

if show1 and price1 > 0
    line.new(bar_index - 50, price1, bar_index, price1, color=color1, width=3)
    label.new(bar_index + 2, price1, label1, color=color.new(color1, 70), textcolor=color1, style=label.style_label_right, size=size.normal)

if show2 and price2 > 0
    line.new(bar_index - 50, price2, bar_index, price2, color=color2, width=3)
    label.new(bar_index + 2, price2, label2, color=color.new(color2, 70), textcolor=color2, style=label.style_label_right, size=size.normal)

if show3 and price3 > 0
    line.new(bar_index - 50, price3, bar_index, price3, color=color3, width=3)
    label.new(bar_index + 2, price3, label3, color=color.new(color3, 70), textcolor=color3, style=label.style_label_right, size=size.normal)

if show4 and price4 > 0
    line.new(bar_index - 50, price4, bar_index, price4, color=color4, width=3)
    label.new(bar_index + 2, price4, label4, color=color.new(color4, 70), textcolor=color4, style=label.style_label_right, size=size.normal)

if show5 and price5 > 0
    line.new(bar_index - 50, price5, bar_index, price5, color=color5, width=3)
    label.new(bar_index + 2, price5, label5, color=color.new(color5, 70), textcolor=color5, style=label.style_label_right, size=size.normal)
