//@version=5
indicator("QQQ GEX Confluence - Manual", overlay=true)

// Input fields for manual confluence levels
// Copy these from your data.json file

// Level 1
input bool SHOW_LEVEL_1 = true
input float LEVEL_1_STRIKE = 695.0
input string LEVEL_1_TAGS = "0DTE CW + Agg PW + Flip"
input int LEVEL_1_SCORE = 7
input string LEVEL_1_TYPE = "FLIP"

// Level 2
input bool SHOW_LEVEL_2 = true
input float LEVEL_2_STRIKE = 700.0
input string LEVEL_2_TAGS = "Agg CW + Top 10 GEX"
input int LEVEL_2_SCORE = 4
input string LEVEL_2_TYPE = "CALL"

// Level 3
input bool SHOW_LEVEL_3 = true
input float LEVEL_3_STRIKE = 690.0
input string LEVEL_3_TAGS = "HVL + Max D1"
input int LEVEL_3_SCORE = 3
input string LEVEL_3_TYPE = "PUT"

// Level 4
input bool SHOW_LEVEL_4 = false
input float LEVEL_4_STRIKE = 0.0
input string LEVEL_4_TAGS = ""
input int LEVEL_4_SCORE = 0
input string LEVEL_4_TYPE = "NEUTRAL"

// Level 5
input bool SHOW_LEVEL_5 = false
input float LEVEL_5_STRIKE = 0.0
input string LEVEL_5_TAGS = ""
input int LEVEL_5_SCORE = 0
input string LEVEL_5_TYPE = "NEUTRAL"

// Colors
color get_level_color(string ltype) =>
    switch ltype
        "CALL" => color.new(#00FF00, 0)   // Green
        "PUT" => color.new(#FF0000, 0)    // Red
        "FLIP" => color.new(#FFFF00, 0)   // Yellow
        => color.new(#FFFFFF, 0)           // White

// Function to draw a single level
void draw_level(bool show, float strike, string tags, int score, string ltype) =>
    if show and strike > 0
        clr = get_level_color(ltype)
        
        // Draw horizontal line
        line.new(
            x1=bar_index - 100,
            y1=strike,
            x2=bar_index,
            y2=strike,
            xloc=xloc.bar_index,
            color=clr,
            style=line.style_solid,
            width=3
        )
        
        // Draw label
        label.new(
            x=bar_index + 5,
            y=strike,
            text="⚡" + str.tostring(score) + " " + tags + " @" + str.tostring(strike, format.mintick),
            xloc=xloc.bar_index,
            color=color.new(clr, 70),
            textcolor=clr,
            size=size.normal,
            style=label.style_label_right
        )

// Draw all levels
draw_level(SHOW_LEVEL_1, LEVEL_1_STRIKE, LEVEL_1_TAGS, LEVEL_1_SCORE, LEVEL_1_TYPE)
draw_level(SHOW_LEVEL_2, LEVEL_2_STRIKE, LEVEL_2_TAGS, LEVEL_2_SCORE, LEVEL_2_TYPE)
draw_level(SHOW_LEVEL_3, LEVEL_3_STRIKE, LEVEL_3_TAGS, LEVEL_3_SCORE, LEVEL_3_TYPE)
draw_level(SHOW_LEVEL_4, LEVEL_4_STRIKE, LEVEL_4_TAGS, LEVEL_4_SCORE, LEVEL_4_TYPE)
draw_level(SHOW_LEVEL_5, LEVEL_5_STRIKE, LEVEL_5_TAGS, LEVEL_5_SCORE, LEVEL_5_TYPE)

// ============================================================
// HOW TO USE THIS INDICATOR
// ============================================================
//
// 1. Copy this entire script into TradingView Pine Editor
// 2. Click "Add to Chart"
// 3. To update levels:
//    - Copy values from your data.json confluence array
//    - Paste into the Input fields above
//    - Click "Add to Chart" again
//
// FOR AUTOMATIC UPDATES:
// - TradingView Free: Use the manual input version above
// - TradingView Pro+: Use the request.text() version
//   (requires paid subscription for external data requests)
//
// ============================================================

// ============================================================
// FULLY AUTOMATIC VERSION (PRO+ ONLY)
// ============================================================

//@version=5
indicator("QQQ GEX Confluence Auto [Pro]", overlay=true, max_lines_count=500)

// Data URL
string DATA_URL = "https://raw.githubusercontent.com/kebabtiabderrahmane-boop/qqq-gex-bot/main/data.json"

// Refresh settings
int REFRESH_SECONDS = 60

// Display settings
int MIN_SCORE = 2
int MAX_LEVELS = 10
color COLOR_CALL = #00FF00
color COLOR_PUT = #FF0000
color COLOR_FLIP = #FFFF00
color COLOR_TEXT = #FFFFFF

// State
var bool data_loaded = false
var float spot_price = na
var string last_update = ""
var line[] lines = array.new_line()
var label[] labels = array.new_label()

// JSON Parsing
string extract(string json, string key) =>
    pos = str.pos(json, '"' + key + '":')
    na(pos) ? "" : str.substring(json, pos + str.length('"' + key + '":'), str.length(json))

float extract_float(string json, string key) =>
    str_val = extract(json, key)
    str_val == "" ? na : float(str.replace_all(str.replace_all(str_val, " ", ""), "\"", ""))

string extract_str(string json, string key) =>
    str_val = extract(json, key)
    str_val == "" ? "" : str.replace_all(str.replace_all(str_val, "\"", ""), " ", "")

string get_array(string json, string key) =>
    marker = '"' + key + '":['
    pos = str.pos(json, marker)
    na(pos) ? "" : str.substring(json, pos + str.length(marker), str.length(json))

// Parse levels from array string
void parse_levels(string arr) =>
    if arr == ""
        return
    
    // Simple object parsing
    // Look for strike values and their associated data
    // This is simplified - production code would properly parse JSON
    
    // Find all strike values
    strike_pos = 0
    while true
        strike_pos := str.pos(arr, '"strike":', strike_pos > 0 ? strike_pos + 1 : 0)
        if na(strike_pos)
            break
        
        // Extract the object containing this strike
        obj_start = str.pos(arr, "{", strike_pos)
        bracket_count = 0
        obj_end = obj_start
        for i = obj_start to str.length(arr) - 1
            c = str.substring(arr, i, i + 1)
            if c == "{"
                bracket_count += 1
            if c == "}"
                bracket_count -= 1
                if bracket_count == 0
                    obj_end := i + 1
                    break
        
        obj = str.substring(arr, obj_start, obj_end)
        
        strike_str = extract_str(obj, "strike")
        tags = extract_str(obj, "tags")
        score_str = extract_str(obj, "score")
        typ = extract_str(obj, "type")
        
        if strike_str != "" and not na(float(strike_str))
            // Successfully parsed a level
            // In production, add to arrays for drawing
            strike_val = float(strike_str)
            score_val = int(float(score_str))
            
            if score_val >= MIN_SCORE
                // Draw this level
                clr = typ == "CALL" ? COLOR_CALL : typ == "PUT" ? COLOR_PUT : typ == "FLIP" ? COLOR_FLIP : COLOR_TEXT
                
                // Line
                l = line.new(bar_index - 50, strike_val, bar_index, strike_val, xloc.bar_index, clr, line.style_solid, 3)
                array.push(lines, l)
                
                // Label
                lb = label.new(bar_index + 2, strike_val, "⚡" + score_str + " " + tags, xloc.bar_index, color.new(clr, 50), clr, size.normal, label.style_label_right)
                array.push(labels, lb)

// Fetch and update
if (na(last_update) or (timenow - last_update) / 1000 > REFRESH_SECONDS)
    string data = request.text(DATA_URL)
    if not na(data) and str.length(data) > 0
        spot_price := extract_float(data, "spot")
        last_update := timenow
        data_loaded := true
        
        // Clear old drawings
        for i = 0 to array.size(lines) - 1
            line.delete(array.get(lines, i))
        for i = 0 to array.size(labels) - 1
            label.delete(array.get(labels, i))
        array.clear(lines)
        array.clear(labels)
        
        // Parse and draw levels
        conf_arr = get_array(data, "confluence")
        parse_levels(conf_arr)

// Plot spot as reference
plot(spot_price, "Spot", color.blue, 2, display=display.all)

// Status in data window
plotshape(data_loaded, "Loaded", shape.cross, location.abovebar, color.lime, size=size.tiny, display=display.data_window)

// ============================================================
// END OF INDICATOR
// ============================================================
