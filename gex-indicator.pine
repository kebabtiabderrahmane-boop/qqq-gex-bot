// If data was fetched successfully, parse it
// if not na(fetch_data_result) and str.length(fetch_data_result) > 0
//     g_spot_price := json_get_float(fetch_data_result, "spot")
//     conf_array = json_get_array(fetch_data_result, "confluence")
//     parse_confluence_array(conf_array)
//     g_is_loaded := true

// Draw confluence levels
if g_is_loaded
    draw_confluence_levels()
    update_info_panel()

// For TradingView Free users, here's a workaround:
// You can manually update by toggling the indicator off/on
// Or use the built-in inputs to set levels manually

// Plot spot price as a reference line (optional)
plot(g_spot_price, title="Spot Price", color=color.blue, linewidth=2, style=plot.style_line, display=display.all)

// Show loading status
plotshape(g_is_loaded, title="Data Status", style=shape.labeldown, location=location.abovebar, color=color.green, size=size.tiny, display=display.data_window)

// ============================================================
// SIMPLIFIED VERSION FOR FREE USERS
